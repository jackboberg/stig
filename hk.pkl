amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ["cargo-fmt"] = Builtins.cargo_fmt
      // Override the builtin: add --all-targets so test code is linted (matching
      // CI), and add -D warnings so unfixable lints fail the commit rather than
      // being silently skipped.
      ["cargo-clippy"] = (Builtins.cargo_clippy) {
        check = "cargo clippy --manifest-path Cargo.toml --all-targets --quiet -- -D warnings"
        fix   = "cargo clippy --manifest-path Cargo.toml --all-targets --fix --allow-dirty --allow-staged --quiet"
      }
    }
  }
  ["commit-msg"] {
    steps {
      ["check-conventional-commit"] = Builtins.check_conventional_commit
    }
  }
}
