amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Builtins.pkl"

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ["cargo-fmt"] = Builtins.`cargo-fmt`
      ["cargo-clippy"] = Builtins.`cargo-clippy`
    }
  }
  ["commit-msg"] {
    steps {
      ["check-conventional-commit"] = Builtins.`check-conventional-commit`
    }
  }
}
